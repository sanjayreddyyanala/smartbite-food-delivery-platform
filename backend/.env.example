PORT=8080
MONGO_URI=mongodb://localhost:27017/food-delivery
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password

# Google Maps (server-side key)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

FRONTEND_URL=http://localhost:5173
# In production on Render, set this to your Vercel app URL.
# Optional: comma-separated list for multiple allowed origins (prod + preview)
# FRONTEND_URLS=https://yourapp.vercel.app,https://yourapp-git-main-yourteam.vercel.app
NODE_ENV=development
